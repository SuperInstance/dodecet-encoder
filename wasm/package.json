    "test": "wasm-pack test --node",
    "test:firefox": "wasm-pack test --firefox",
    "test:chrome": "wasm-pack test --chrome",
    "publish:dry": "npm publish --dry-run",
    "publish:public": "npm publish --access public"
  },
  "devDependencies": {
    "wasm-pack": "^0.12.1"
