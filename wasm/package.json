{
  "name": "@superinstance/dodecet-encoder",
  "version": "1.1.0",
  "description": "12-bit dodecet encoding for geometric operations - WebAssembly library",
  "keywords": [
    "dodecet",
    "12-bit",
    "encoding",
    "geometry",
    "webassembly",
    "wasm",
    "3d",
    "vector",
    "transformation",
    "calculus",
    "graphics"
  ],
  "author": "SuperInstance Team <team@superinstance.ai>",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/dodecet-encoder.git"
  },
  "homepage": "https://superinstance.ai",
  "bugs": {
    "url": "https://github.com/SuperInstance/dodecet-encoder/issues"
  },
  "main": "dodecet_wasm.js",
  "module": "dodecet_wasm.js",
  "types": "dodecet_wasm.d.ts",
  "sideEffects": false,
  "files": [
    "dodecet_wasm.js",
    "dodecet_wasm_bg.wasm",
    "dodecet_wasm.d.ts",
    "dodecet_wasm_bg.js",
